	<classpathentry kind="lib" path="lib/jlayer-1.0.1.jar" sourcepath="lib/jlayer-1.0.1.jar"/>
	<classpathentry kind="lib" path="lib/robot.jar" sourcepath="lib/robot.jar"/>
	<classpathentry kind="lib" path="lib/TokenHacker.jar" sourcepath="lib/TokenHacker.jar"/>
	<classpathentry kind="output" path="bin"/>
</classpath>
